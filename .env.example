# Database
DATABASE_URL=postgresql://user:password@localhost:5432/returnit

# AI
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
QWEN_VISION_MODEL=qwen3.5-plus

# Matching tuning
VECTOR_CANDIDATE_COUNT=20
FINAL_RESULT_COUNT=12

# Auth
SESSION_SECRET=change-me-in-production
SESSION_SECURE=false

# Map
VITE_KAKAO_MAP_KEY=

# Social Login (optional)
# Kakao: https://developers.kakao.com
KAKAO_CLIENT_ID=
KAKAO_CALLBACK_URL=http://localhost:8080/api/auth/kakao/callback
VITE_KAKAO_LOGIN_ENABLED=false

# Google: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback
VITE_GOOGLE_LOGIN_ENABLED=false

# Server
PORT=8080
HOST=127.0.0.1
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=50mb
