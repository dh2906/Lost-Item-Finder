DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/lost_found_finder"
PORT="8080"
REQUEST_BODY_LIMIT="50mb"
ALLOW_NGROK_ORIGINS="false"

# Required in production. Use at least 32 random characters.
SESSION_SECRET="replace-with-a-long-random-session-secret"
# Use true behind HTTPS in production. Keep false only for local HTTP testing.
SESSION_SECURE="false"
# Comma-separated list of admin usernames or emails. Change this before deploying.
ADMIN_USERNAMES="change-me-admin-username"

# OAuth login. Register these callback URLs in each provider console:
# {PUBLIC_URL}/api/auth/oauth/google/callback
# {PUBLIC_URL}/api/auth/oauth/kakao/callback
# {PUBLIC_URL}/api/auth/oauth/naver/callback
# Production Google OAuth requires these 6 deployment env vars:
# SESSION_SECRET, SESSION_SECURE, PUBLIC_URL, OAUTH_CALLBACK_BASE_URL,
# GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET
PUBLIC_URL="http://localhost:8080"
OAUTH_CALLBACK_BASE_URL="http://localhost:8080"
OAUTH_REQUEST_TIMEOUT_MS="10000"
GOOGLE_OAUTH_CLIENT_ID="replace-with-google-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="replace-with-google-client-secret"
KAKAO_OAUTH_CLIENT_ID="replace-with-kakao-rest-api-key"
KAKAO_OAUTH_CLIENT_SECRET="replace-with-kakao-client-secret"
NAVER_OAUTH_CLIENT_ID="replace-with-naver-client-id"
NAVER_OAUTH_CLIENT_SECRET="replace-with-naver-client-secret"

# Cost controls
# Keep these disabled unless you explicitly want paid LLM post-processing.
AI_RERANK_ENABLED="false"
AI_RERANK_MAX_CANDIDATES="10"
AI_SEARCH_GEOCODE_TIMEOUT_MS="2000"
AI_SEARCH_IMAGE_TIMEOUT_MS="20000"
AI_SEARCH_RERANK_TIMEOUT_MS="12000"
AUTOMATIC_MATCH_QUEUE_ENABLED="false"
OPENAI_IMAGE_METADATA_NORMALIZE_ENABLED="false"

# GPT text-only paths. Optional when the cost controls above stay disabled
# and EMBEDDING_PROVIDER=local.
AI_INTEGRATIONS_OPENAI_API_KEY="replace-with-your-gpt-key"
AI_INTEGRATIONS_OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_TEXT_MODEL="gpt-5-nano"
EMBEDDING_PROVIDER="local"
EMBEDDING_DIMENSIONS="768"
LOCAL_EMBEDDING_URL="http://127.0.0.1:8090/embed"
LOCAL_EMBEDDING_MODEL="intfloat/multilingual-e5-base"
EMBEDDING_REQUEST_TIMEOUT_MS="10000"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
VECTOR_CANDIDATE_COUNT="40"
FINAL_RESULT_COUNT="24"
AI_RATE_LIMIT_WINDOW_MS="60000"
AI_SEARCH_GUEST_RATE_LIMIT="20"
AI_SEARCH_USER_RATE_LIMIT="60"
AI_IMAGE_ANALYSIS_RATE_LIMIT="20"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
AUTH_LOGIN_RATE_LIMIT="10"
CHAT_RATE_LIMIT_WINDOW_MS="60000"
CHAT_MESSAGE_RATE_LIMIT="30"
AUTO_MATCH_MIN_SCORE="0.62"
AUTO_MATCH_MAX_RESULTS="5"
AUTO_MATCH_DATE_WINDOW_DAYS="90"

# Lost112 public data portal
LOST112_API_KEY="replace-with-your-public-data-service-key"
LOST112_SYNC_ENABLED="true"
LOST112_SYNC_INTERVAL_MS="1800000"
LOST112_SYNC_INITIAL_DELAY_MS="60000"
LOST112_SYNC_START_PAGE="1"
LOST112_SYNC_NUM_ROWS="100"
LOST112_SYNC_MAX_PAGES="10"
LOST112_SYNC_LOOKBACK_DAYS="1"
LOST112_SYNC_AUTO_MATCH_ENABLED="false"

# Kakao Local REST API key for Lost112 location enrichment and server-side reverse geocoding cache
KAKAO_REST_API_KEY="replace-with-your-kakao-rest-api-key"
REVERSE_GEOCODE_CACHE_TTL_MS="86400000"
REVERSE_GEOCODE_CACHE_LIMIT="10000"
REVERSE_GEOCODE_RATE_LIMIT_WINDOW_MS="60000"
REVERSE_GEOCODE_GUEST_RATE_LIMIT="60"
REVERSE_GEOCODE_USER_RATE_LIMIT="180"

# Qwen image-analysis paths
QWEN_API_KEY="replace-with-your-qwen-key"
QWEN_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/v1"
QWEN_TEXT_MODEL="qwen3.5-plus"
QWEN_VISION_MODEL="qwen3.5-plus"
LOST112_NORMALIZE_PROVIDER="none"
LOST112_NORMALIZE_MODEL="qwen3.5-plus"

# Firebase 서버용 (Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성)
FIREBASE_SERVICE_ACCOUNT_JSON="{'type':'service_account','project_id':'your-project-id','private_key_id':'replace','private_key':'-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n','client_email':'firebase-adminsdk@your-project-id.iam.gserviceaccount.com','client_id':'replace','auth_uri':'https://accounts.google.com/o/oauth2/auth','token_uri':'https://oauth2.googleapis.com/token','auth_provider_x509_cert_url':'https://www.googleapis.com/oauth2/v1/certs','client_x509_cert_url':'replace','universe_domain':'googleapis.com'}"

# Firebase 클라이언트용 (Firebase 콘솔 → 프로젝트 설정 → 내 앱)
VITE_FIREBASE_API_KEY="replace-with-your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="replace-with-sender-id"
VITE_FIREBASE_APP_ID="replace-with-app-id"

# Firebase 웹 푸시 인증서 (Firebase 콘솔 → 프로젝트 설정 → 클라우드 메시징 → 웹 푸시 인증서)
VITE_FIREBASE_VAPID_KEY="replace-with-your-vapid-key"

# Kakao Maps JavaScript 키 (Kakao Developers → 내 애플리케이션 → 앱 키 → JavaScript 키)
VITE_KAKAO_MAP_KEY="replace-with-your-kakao-javascript-key"

# PWA 개발 모드 (dev 환경에서 Service Worker 활성화할 때만 true로 설정)
# VITE_PWA_DEV=true
