DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/lost_found_finder"
PORT="8080"
REQUEST_BODY_LIMIT="50mb"
ADMIN_USERNAMES="admin"

# GPT text-only paths
AI_INTEGRATIONS_OPENAI_API_KEY="replace-with-your-gpt-key"
AI_INTEGRATIONS_OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
VECTOR_CANDIDATE_COUNT="40"
FINAL_RESULT_COUNT="12"

# Qwen image-analysis paths
QWEN_API_KEY="replace-with-your-qwen-key"
QWEN_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/v1"
QWEN_VISION_MODEL="qwen3.5-plus"

# Firebase 서버용 (Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성)
FIREBASE_SERVICE_ACCOUNT_JSON="{'type':'service_account','project_id':'your-project-id','private_key_id':'replace','private_key':'-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n','client_email':'firebase-adminsdk@your-project-id.iam.gserviceaccount.com','client_id':'replace','auth_uri':'https://accounts.google.com/o/oauth2/auth','token_uri':'https://oauth2.googleapis.com/token','auth_provider_x509_cert_url':'https://www.googleapis.com/oauth2/v1/certs','client_x509_cert_url':'replace','universe_domain':'googleapis.com'}"

# Firebase 클라이언트용 (Firebase 콘솔 → 프로젝트 설정 → 내 앱)
VITE_FIREBASE_API_KEY="replace-with-your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="replace-with-sender-id"
VITE_FIREBASE_APP_ID="replace-with-app-id"

# Firebase 웹 푸시 인증서 (Firebase 콘솔 → 프로젝트 설정 → 클라우드 메시징 → 웹 푸시 인증서)
VITE_FIREBASE_VAPID_KEY="replace-with-your-vapid-key"

# PWA 개발 모드 (dev 환경에서 Service Worker 활성화할 때만 true로 설정)
# VITE_PWA_DEV=true
